{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ai/schema/metrics.json",
  "title": "EvalMetrics",
  "type": "object",
  "required": ["run_id", "domain", "scenarios"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this evaluation run"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp when evaluation was run"
    },
    "domain": {
      "type": "string",
      "enum": ["driving", "robotics", "rl"],
      "description": "Domain for evaluation metrics"
    },
    "git": {
      "type": "object",
      "description": "Git repository info for reproducibility",
      "properties": {
        "repo": {"type": "string"},
        "commit": {"type": "string"},
        "branch": {"type": "string"}
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "description": "Policy configuration",
      "properties": {
        "name": {"type": "string"},
        "checkpoint": {"type": "string"},
        "type": {"type": "string", "enum": ["sft", "rl", "hybrid"]}
      },
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "description": "Per-scenario metrics",
      "items": {
        "type": "object",
        "required": ["scenario_id", "success"],
        "properties": {
          "scenario_id": {"type": "string"},
          "success": {"type": "boolean"},
          "ade": {
            "type": "number",
            "description": "Average Displacement Error - mean distance to target waypoints (meters)"
          },
          "fde": {
            "type": "number",
            "description": "Final Displacement Error - distance to final target waypoint (meters)"
          },
          "route_completion": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Fraction of route completed"
          },
          "collisions": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of collision events"
          },
          "offroad": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of off-road events"
          },
          "red_light": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of red light violations"
          },
          "return": {
            "type": "number",
            "description": "Episode return (cumulative reward)"
          },
          "steps": {
            "type": "integer",
            "description": "Number of steps taken"
          },
          "final_dist": {
            "type": "number",
            "description": "Final distance to target (meters)"
          },
          "comfort": {
            "type": "object",
            "description": "Comfort metrics",
            "properties": {
              "max_accel": {"type": "number"},
              "max_jerk": {"type": "number"}
            },
            "additionalProperties": true
          },
          "raw": {
            "type": "object",
            "description": "Pass-through raw metrics from evaluator",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "description": "Aggregate metrics across all scenarios",
      "properties": {
        "ade_mean": {"type": "number"},
        "ade_std": {"type": "number"},
        "fde_mean": {"type": "number"},
        "fde_std": {"type": "number"},
        "success_rate": {"type": "number"},
        "return_mean": {"type": "number"},
        "return_std": {"type": "number"},
        "steps_mean": {"type": "number"},
        "num_episodes": {"type": "integer"}
      },
      "additionalProperties": true
    },
    "comparison": {
      "type": "object",
      "description": "Comparison between baseline and policy (if applicable)",
      "properties": {
        "baseline_policy": {"type": "string"},
        "target_policy": {"type": "string"},
        "ade_improvement_pct": {"type": "number"},
        "fde_improvement_pct": {"type": "number"},
        "success_rate_diff": {"type": "number"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
